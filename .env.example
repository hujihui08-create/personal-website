# 公共环境变量模板
# 复制此文件为 .env.development 或 .env.production 并填写实际值

# ==================== 前端配置 ====================
VITE_API_BASE_URL=http://localhost:8080/api
VITE_UPLOAD_URL=http://localhost:9000

# ==================== 后端配置 ====================
# 数据库
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_NAME=portfolio_dev

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# MinIO 对象存储
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=portfolio

# JWT 认证
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_EXPIRATION=168h

# 服务模式
GIN_MODE=debug

# CORS 配置（多个域名用逗号分隔）
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# 邮件服务配置
# 支持的提供商：brevo（推荐，每天免费300封）、smtp、sendgrid
EMAIL_PROVIDER=brevo
EMAIL_API_KEY=your-brevo-api-key
EMAIL_FROM=noreply@example.com
EMAIL_FROM_NAME=个人网站
EMAIL_ADMIN=admin@example.com

# SMTP 配置（仅当 EMAIL_PROVIDER=smtp 时需要）
EMAIL_SMTP_HOST=smtp-relay.brevo.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=your-smtp-user
EMAIL_SMTP_PASSWORD=your-smtp-password

# LLM API 配置（用于 Agent）
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4-turbo-preview
