# ==================================================
# 生产环境配置模板
# 复制此文件为 .env.production 并填入真实值
# ==================================================

# ==================================================
# 域名配置
# ==================================================
DOMAIN=dundun.store

# ==================================================
# 数据库配置
# ==================================================
DB_PASSWORD=请输入强密码（至少16位，包含大小写字母、数字、特殊字符

# ==================================================
# MinIO 配置
# ==================================================
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=请输入强密码
MINIO_BUCKET=portfolio

# ==================================================
# JWT 认证配置
# ==================================================
JWT_SECRET=请输入至少32位随机字符串作为JWT密钥
JWT_EXPIRATION=168h

# ==================================================
# 邮件服务配置
# ==================================================
EMAIL_PROVIDER=brevo
EMAIL_API_KEY=请输入BrevoAPI密钥
EMAIL_FROM=noreply@dundun.store
EMAIL_FROM_NAME=个人网站
EMAIL_ADMIN=your-email@example.com

# ==================================================
# LLM API 配置（用于 Agent）
# ==================================================
LLM_PROVIDER=dashscope
LLM_API_KEY=请输入阿里云百炼API密钥
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_CHAT_MODEL=qwen-plus
LLM_EMBEDDING_MODEL=text-embedding-v4
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7
LLM_DAILY_LIMIT=50
